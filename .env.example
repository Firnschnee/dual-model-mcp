# Copy this file to .env and paste your real OpenRouter API key.
# Get one at https://openrouter.ai -> Settings -> Keys
OPENROUTER_API_KEY=your_actual_api_key_here

# --- Optional overrides (defaults shown) ---

# Comma-separated OpenRouter model IDs to query in parallel (2 or more)
#MODELS=anthropic/claude-opus-4.8,openai/gpt-5.5

# Model used for the optional synthesis step (cheap model recommended)
#SYNTHESIS_MODEL=anthropic/claude-haiku-4.5

# Max output tokens per model
#MAX_TOKENS=6000

# Sampling temperature (0-2)
#TEMPERATURE=0.7

# Per-request timeout in milliseconds
#REQUEST_TIMEOUT_MS=120000

# --- HTTP mode only (npm run start:http, for remote access / claude.ai) ---

# Required in HTTP mode: secret URL path segment, min. 16 chars.
# Generate e.g. with: openssl rand -hex 24
#MCP_PATH_SECRET=

# Bind address and port (keep 127.0.0.1 behind a reverse proxy)
#MCP_HTTP_HOST=127.0.0.1
#MCP_HTTP_PORT=3777
